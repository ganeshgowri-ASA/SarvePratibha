# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sarve_pratibha?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Server ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# ─── NextAuth (apps/web) ────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# ─── Google OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Public (client-side, apps/web) ─────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_NAME="SarvePratibha"

# ─── Email / SMTP ───────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@sarvepratibha.com"

# ─── SendGrid (alternative email provider) ──────────────────────────
SENDGRID_API_KEY="your-sendgrid-api-key"

# ─── Twilio (SMS) ───────────────────────────────────────────────────
TWILIO_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE="+1234567890"

# ─── AI Chat (HR Buddy chatbot) ─────────────────────────────────────
# Optional: enables GPT-4o-mini powered HR Buddy. Falls back to offline mode if not set.
OPENAI_API_KEY="sk-your-openai-api-key"

# ─── AI Voice / Screening Providers ─────────────────────────────────
VAPI_API_KEY="your-vapi-api-key"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
SARVAM_API_KEY="your-sarvam-api-key"

# ─── File Storage ───────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL="debug"
