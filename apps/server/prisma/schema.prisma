// ─── USER & AUTHENTICATION ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  image         String?
  role          UserRole  @default(EMPLOYEE)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // OAuth accounts
  accounts Account[]
  sessions Session[]

  // Employee profile
  employee Employee?

  // Notifications
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  pushSubscriptions       PushSubscription[]
  quietHours              QuietHours?

  // Audit trail
  auditLogs AuditLog[]

  // Admin / System
  userSessions UserSession[]
  loginHistory LoginHistory[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── ROLE & PERMISSION ──────────────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

// ─── ORGANIZATION STRUCTURE ─────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  logo      String?
  website   String?
  address   String?
  city      String?
  state     String?
  country   String?
  pincode   String?
  phone     String?
  email     String?
  taxId     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments Department[]
  employees   Employee[]

  @@map("organizations")
}

model Department {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  description    String?
  organizationId String
  parentId       String?
  headId         String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  parent          Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children        Department[]     @relation("DepartmentHierarchy")
  employees       Employee[]
  jobPostings     JobPosting[]
  jobRequisitions JobRequisition[]

  @@index([organizationId])
  @@index([parentId])
  @@map("departments")
}

model Designation {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  level     Int      @default(0)
  band      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees       Employee[]
  jobRequisitions JobRequisition[]

  @@map("designations")
}

// ─── EMPLOYEE ───────────────────────────────────────────────────────

model Employee {
  id                  String           @id @default(cuid())
  employeeId          String           @unique
  userId              String           @unique
  organizationId      String
  departmentId        String
  designationId       String
  managerId           String?
  firstName           String
  lastName            String
  middleName          String?
  dateOfBirth         DateTime?
  gender              Gender?
  maritalStatus       MaritalStatus?
  phone               String?
  personalEmail       String?
  address             String?
  city                String?
  state               String?
  country             String?
  pincode             String?
  dateOfJoining       DateTime
  dateOfLeaving       DateTime?
  probationEndDate    DateTime?
  employmentStatus    EmploymentStatus @default(ACTIVE)
  employmentType      EmploymentType   @default(FULL_TIME)
  panNumber           String?
  aadharNumber        String?
  bankAccountNo       String?
  bankName            String?
  ifscCode            String?
  pfNumber            String?
  uanNumber           String?
  esiNumber           String?
  emergencyContact    String?
  emergencyPhone      String?
  bloodGroup          String?
  profilePhoto        String?
  // Extended personal details
  title               String?
  maritalSinceDate    DateTime?
  nationality         String?
  placeOfBirth        String?
  stateOfBirth        String?
  religion            String?
  identificationMark  String?
  heightCm            Float?
  weightKg            Float?
  motherTongue        String?
  caste               String?
  // Contact details
  corporatePhone      String?
  personalPhone       String?
  residentialPhone    String?
  officePhone         String?
  officialEmail       String?
  // Address
  workLocation        String?
  permanentAddress    String?
  permanentCity       String?
  permanentState      String?
  permanentCountry    String?
  permanentPincode    String?
  // Bank details
  bankBranch          String?
  // Additional dates
  confirmationDate    DateTime?
  lastPromotionDate   DateTime?
  lastCertifiedDate   DateTime?
  // Dotted line manager
  dottedLineManagerId String?
  orgUnitChiefId      String?
  // Passport / DL
  passportNumber      String?
  drivingLicense      String?
  voterIdNumber       String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])
  designation  Designation  @relation(fields: [designationId], references: [id])

  // Self-referential manager relationship
  manager       Employee?  @relation("ManagerReports", fields: [managerId], references: [id])
  directReports Employee[] @relation("ManagerReports")

  // Dotted line and org unit chief
  dottedLineManager   Employee?  @relation("DottedLineReports", fields: [dottedLineManagerId], references: [id])
  dottedLineReports   Employee[] @relation("DottedLineReports")
  orgUnitChief        Employee?  @relation("OrgUnitChiefReports", fields: [orgUnitChiefId], references: [id])
  orgUnitChiefReports Employee[] @relation("OrgUnitChiefReports")

  // Related detail records
  familyMembers     FamilyMember[]
  nominations       Nomination[]
  personalDocuments PersonalDocument[]
  educationRecords  EducationRecord[]
  experienceRecords ExperienceRecord[]

  // Leave
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  // Attendance
  attendances     Attendance[]
  punchRecords    PunchRecord[]
  regularizations AttendanceRegularization[]

  // Shift
  shiftSchedules ShiftSchedule[]

  // Special requests
  compOffRequests CompOff[]
  wfhRequests     WorkFromHome[]
  onDutyRequests  OnDuty[]

  // Payroll
  payrollStructure PayrollStructure?
  payslips         Payslip[]
  taxDeclarations  TaxDeclaration[]

  // Claims & Loans
  claims Claim[]
  loans  Loan[]

  // Payroll Extended
  form16s        Form16[]
  investments    Investment[]
  reimbursements Reimbursement[]

  // Performance
  performanceGoals     PerformanceGoal[]
  reviewsAsReviewee    Review[]           @relation("ReviewReviewee")
  reviewsAsReviewer    Review[]           @relation("ReviewReviewer")
  goalProgress         GoalProgress[]
  competencyRatings    CompetencyRating[]
  pipsAsEmployee       PIP[]              @relation("PIPEmployee")
  pipsAsCreator        PIP[]              @relation("PIPCreator")
  feedback360Requested Feedback360[]      @relation("Feedback360Requester")
  feedback360Target    Feedback360[]      @relation("Feedback360Target")
  feedbackResponses    FeedbackResponse[]
  kras                 KRA[]

  // Talent / Recruitment
  applications            Application[]
  interviewsAsInterviewer InterviewSchedule[] @relation("Interviewer")
  interviewFeedbacks      InterviewFeedback[]
  requisitionsCreated     JobRequisition[]    @relation("RequisitionCreator")
  requisitionsApproved    JobRequisition[]    @relation("RequisitionApprover")
  offersCreated           OfferLetter[]       @relation("OfferCreator")
  offersApproved          OfferLetter[]       @relation("OfferApprover")

  // Security & Services
  securityPasses SecurityPass[]
  visitorLogs    VisitorLog[]
  assetRequests  ITAssetRequest[]

  // Travel & Benefits
  travelRequests     TravelRequest[]
  benefitEnrollments BenefitEnrollment[]
  serviceRequests    ServiceRequest[]
  assetAssignments   AssetAssignment[]
  helpdeskTickets    HelpdeskTicket[]
  meetingBookings    MeetingBooking[]
  cabRequests        CabRequest[]
  foodCoupons        FoodCoupon[]
  giftVouchers       GiftVoucher[]

  @@index([employeeId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([managerId])
  @@index([employmentStatus])
  @@map("employees")
}

// ─── EMPLOYEE DETAILS ──────────────────────────────────────────────

model FamilyMember {
  id           String       @id @default(cuid())
  employeeId   String
  name         String
  relationship Relationship
  dateOfBirth  DateTime?
  gender       Gender?
  occupation   String?
  phone        String?
  isDependent  Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("family_members")
}

model Nomination {
  id           String         @id @default(cuid())
  employeeId   String
  type         NominationType
  nomineeName  String
  relationship Relationship
  dateOfBirth  DateTime?
  percentage   Float
  address      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("nominations")
}

model PersonalDocument {
  id             String       @id @default(cuid())
  employeeId     String
  documentType   DocumentType
  documentNumber String
  fileUrl        String?
  fileName       String?
  isVerified     Boolean      @default(false)
  expiryDate     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, documentType])
  @@index([employeeId])
  @@map("personal_documents")
}

model EducationRecord {
  id             String   @id @default(cuid())
  employeeId     String
  degree         String
  institution    String
  university     String?
  yearOfPassing  Int?
  percentage     Float?
  grade          String?
  specialization String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("education_records")
}

model ExperienceRecord {
  id               String    @id @default(cuid())
  employeeId       String
  companyName      String
  designation      String
  fromDate         DateTime
  toDate           DateTime?
  isCurrent        Boolean   @default(false)
  reasonForLeaving String?
  lastDrawnSalary  Float?
  location         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("experience_records")
}

// ─── LEAVE MANAGEMENT ───────────────────────────────────────────────

model LeaveType {
  id                String   @id @default(cuid())
  name              String
  code              String   @unique
  description       String?
  defaultDays       Float    @default(0)
  carryForwardLimit Float    @default(0)
  isEncashable      Boolean  @default(false)
  isPaidLeave       Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  @@map("leave_types")
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  startDate     DateTime
  endDate       DateTime
  days          Float
  startDayType  LeaveDay    @default(FULL)
  endDayType    LeaveDay    @default(FULL)
  reason        String?
  attachmentUrl String?
  status        LeaveStatus @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  allocated   Float    @default(0)
  used        Float    @default(0)
  carried     Float    @default(0)
  balance     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

// ─── ATTENDANCE ─────────────────────────────────────────────────────

model Attendance {
  id           String           @id @default(cuid())
  employeeId   String
  date         DateTime         @db.Date
  status       AttendanceStatus @default(PRESENT)
  firstPunchIn DateTime?
  lastPunchOut DateTime?
  totalHours   Float?
  overtime     Float?
  remarks      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
  @@map("attendances")
}

model PunchRecord {
  id         String    @id @default(cuid())
  employeeId String
  punchTime  DateTime  @default(now())
  punchType  PunchType
  location   String?
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, punchTime])
  @@map("punch_records")
}

model ShiftSchedule {
  id         String    @id @default(cuid())
  employeeId String
  name       String
  startTime  String
  endTime    String
  breakMins  Int       @default(60)
  effectFrom DateTime
  effectTo   DateTime?
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("shift_schedules")
}

model HolidayCalendar {
  id         String   @id @default(cuid())
  name       String
  date       DateTime @db.Date
  type       String   @default("NATIONAL") // NATIONAL, OPTIONAL, RESTRICTED
  location   String?
  isOptional Boolean  @default(false)
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, location])
  @@index([year])
  @@index([type])
  @@map("holiday_calendars")
}

model AttendanceRegularization {
  id              String               @id @default(cuid())
  employeeId      String
  date            DateTime             @db.Date
  reason          String
  requestedStatus AttendanceStatus     @default(PRESENT)
  status          RegularizationStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  remarks         String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("attendance_regularizations")
}

model CompOff {
  id          String        @id @default(cuid())
  employeeId  String
  workedDate  DateTime      @db.Date
  compOffDate DateTime?     @db.Date
  reason      String
  hours       Float         @default(8)
  status      RequestStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  remarks     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("comp_offs")
}

model WorkFromHome {
  id         String        @id @default(cuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  days       Float
  reason     String
  status     RequestStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  remarks    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("work_from_home")
}

model OnDuty {
  id         String        @id @default(cuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  days       Float
  reason     String
  location   String?
  status     RequestStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  remarks    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

