// ─── NOTIFICATIONS & ANNOUNCEMENTS ──────────────────────────────────

model Notification {
  id        String               @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType     @default(INFO)
  category  NotificationCategory @default(GENERAL)
  link      String?
  isRead    Boolean              @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, category])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String                @id @default(cuid())
  userId    String
  category  NotificationCategory
  email     Boolean               @default(true)
  sms       Boolean               @default(false)
  push      Boolean               @default(true)
  inApp     Boolean               @default(true)
  frequency NotificationFrequency @default(INSTANT)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("notification_preferences")
}

model NotificationTemplate {
  id        String               @id @default(cuid())
  name      String               @unique
  subject   String
  body      String               @db.Text
  category  NotificationCategory
  channel   NotificationChannel
  variables Json?
  isActive  Boolean              @default(true)
  createdBy String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([category])
  @@index([channel])
  @@map("notification_templates")
}

model EmailLog {
  id        String      @id @default(cuid())
  to        String
  from      String?
  subject   String
  body      String      @db.Text
  status    EmailStatus @default(QUEUED)
  provider  String?
  messageId String?
  error     String?
  attempts  Int         @default(0)
  sentAt    DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([status])
  @@index([to])
  @@index([createdAt])
  @@map("email_logs")
}

model SMSLog {
  id        String    @id @default(cuid())
  to        String
  message   String
  status    SMSStatus @default(QUEUED)
  provider  String?
  messageId String?
  error     String?
  attempts  Int       @default(0)
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([to])
  @@index([createdAt])
  @@map("sms_logs")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  p256dh    String
  auth      String
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model BulkNotification {
  id          String                 @id @default(cuid())
  title       String
  message     String                 @db.Text
  type        NotificationType       @default(INFO)
  category    NotificationCategory   @default(GENERAL)
  targetRoles Json?
  targetDepts Json?
  totalCount  Int                    @default(0)
  sentCount   Int                    @default(0)
  failedCount Int                    @default(0)
  status      BulkNotificationStatus @default(PENDING)
  channels    Json?
  createdBy   String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("bulk_notifications")
}

model QuietHours {
  id        String   @id @default(cuid())
  userId    String   @unique
  enabled   Boolean  @default(false)
  startTime String   @default("22:00")
  endTime   String   @default("07:00")
  timezone  String   @default("Asia/Kolkata")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiet_hours")
}

model Announcement {
  id         String               @id @default(cuid())
  title      String
  content    String
  priority   AnnouncementPriority @default(MEDIUM)
  targetRole UserRole?
  isActive   Boolean              @default(true)
  publishAt  DateTime             @default(now())
  expiresAt  DateTime?
  createdBy  String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([isActive, publishAt])
  @@map("announcements")
}

model Banner {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  link      String?
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, startDate])
  @@map("banners")
}

// ─── AI SCREENING & VOICE ASSISTANT ─────────────────────────────────

enum ScreeningSessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FAILED
}

enum VoiceCallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
}

enum VoiceProvider {
  VAPI
  RETELL
  ELEVENLABS
  SARVAM
}

enum AIRecommendation {
  STRONG_SHORTLIST
  SHORTLIST
  HOLD
  REJECT
}

enum ScreeningQuestionType {
  TECHNICAL
  BEHAVIORAL
  SITUATIONAL
  CULTURAL_FIT
  COMMUNICATION
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  EXPERT
}

model AIScreeningSession {
  id             String                 @id @default(cuid())
  applicationId  String
  jobPostingId   String
  candidateName  String
  candidateEmail String
  candidatePhone String?
  status         ScreeningSessionStatus @default(PENDING)
  templateId     String?
  language       String                 @default("en")
  startedAt      DateTime?
  completedAt    DateTime?
  overallScore   Float?
  recommendation AIRecommendation?
  summary        String?                @db.Text
  initiatedById  String?
  metadata       Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  application Application           @relation(fields: [applicationId], references: [id])
  jobPosting  JobPosting            @relation(fields: [jobPostingId], references: [id])
  template    ScreeningTemplate?    @relation(fields: [templateId], references: [id])
  questions   AIScreeningQuestion[]
  responses   AIScreeningResponse[]
  scores      AIScreeningScore[]
  voiceCalls  VoiceCallLog[]

  @@index([applicationId])
  @@index([jobPostingId])
  @@index([status])
  @@index([createdAt])
  @@map("ai_screening_sessions")
}

model AIScreeningQuestion {
  id             String                @id @default(cuid())
  sessionId      String
  questionText   String                @db.Text
  questionType   ScreeningQuestionType @default(TECHNICAL)
  difficulty     DifficultyLevel       @default(MEDIUM)
  orderIndex     Int                   @default(0)
  expectedAnswer String?               @db.Text
  maxScore       Float                 @default(10)
  timeLimit      Int? // seconds
  createdAt      DateTime              @default(now())

  session   AIScreeningSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses AIScreeningResponse[]

  @@index([sessionId])
  @@map("ai_screening_questions")
}

model AIScreeningResponse {
  id           String    @id @default(cuid())
  sessionId    String
  questionId   String
  responseText String?   @db.Text
  audioUrl     String?
  duration     Int? // seconds
  score        Float?
  sentiment    String? // positive, negative, neutral
  confidence   Float? // 0-1
  feedback     String?   @db.Text
  evaluatedAt  DateTime?
  createdAt    DateTime  @default(now())

  session  AIScreeningSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question AIScreeningQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([questionId])
  @@map("ai_screening_responses")
}

model AIScreeningScore {
  id        String   @id @default(cuid())
  sessionId String
  category  String // Technical, Communication, CulturalFit, Confidence, ProblemSolving
  score     Float
  maxScore  Float    @default(100)
  details   String?  @db.Text
  createdAt DateTime @default(now())

  session AIScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_screening_scores")
}

model VoiceCallLog {
  id             String          @id @default(cuid())
  sessionId      String?
  provider       VoiceProvider   @default(VAPI)
  providerCallId String?         @unique
  candidateName  String
  candidatePhone String
  direction      String          @default("outbound") // inbound or outbound
  status         VoiceCallStatus @default(QUEUED)
  startedAt      DateTime?
  endedAt        DateTime?
  duration       Int? // seconds
  recordingUrl   String?
  costCents      Float?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  session     AIScreeningSession?   @relation(fields: [sessionId], references: [id])
  transcripts VoiceCallTranscript[]

  @@index([sessionId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
  @@map("voice_call_logs")
}

model VoiceCallTranscript {
  id         String   @id @default(cuid())
  callId     String
  speaker    String // "ai" or "candidate"
  text       String   @db.Text
  timestamp  Float // seconds from call start
  confidence Float?
  createdAt  DateTime @default(now())

  call VoiceCallLog @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@map("voice_call_transcripts")
}

model AIAssistantConfig {
  id                 String        @id @default(cuid())
  name               String        @default("AI Screening Assistant")
  voiceProvider      VoiceProvider @default(VAPI)
  voiceId            String?
  personality        String?       @db.Text
  companyContext     String?       @db.Text
  language           String        @default("en")
  supportedLanguages String[]      @default(["en", "hi"])
  maxCallDuration    Int           @default(900) // seconds (15 min default)
  evaluationCriteria Json?
  isActive           Boolean       @default(true)
  createdById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("ai_assistant_configs")
}

model ScreeningTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  roleTitle   String?
  department  String?
  questions   Json // Array of { text, type, difficulty, expectedAnswer, maxScore }
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions AIScreeningSession[]

  @@index([isActive])
  @@map("screening_templates")
}

model CandidateAIScore {
  id                 String            @id @default(cuid())
  applicationId      String
  jobPostingId       String
  technicalScore     Float?
  communicationScore Float?
  culturalFitScore   Float?
  confidenceScore    Float?
  overallScore       Float?
  resumeScore        Float?
  ranking            Int?
  recommendation     AIRecommendation?
  reasoning          String?           @db.Text
  parsedResume       Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  application Application @relation(fields: [applicationId], references: [id])
  jobPosting  JobPosting  @relation(fields: [jobPostingId], references: [id])

  @@unique([applicationId, jobPostingId])
  @@index([jobPostingId])
  @@index([overallScore])
  @@map("candidate_ai_scores")
}

// ─── AUDIT LOG ──────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── TRAVEL MANAGEMENT ───────────────────────────────────────────────

model TravelPolicy {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  perDiemDomestic       Float    @default(0)
  perDiemInternational  Float    @default(0)
  maxHotelDomestic      Float    @default(0)
  maxHotelInternational Float    @default(0)
  advanceBookingDays    Int      @default(7)
  maxAdvancePercent     Float    @default(80)
  flightClass           String   @default("ECONOMY")
  trainClass            String   @default("AC_2TIER")
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("travel_policies")
}

model TravelRequest {
  id                String              @id @default(cuid())
  employeeId        String
  destination       String
  fromCity          String
  travelStartDate   DateTime
  travelEndDate     DateTime
  purpose           String
  estimatedCost     Float               @default(0)
  advanceAmount     Float               @default(0)
  travelMode        String              @default("FLIGHT")
  accommodationType String              @default("HOTEL")
  status            TravelRequestStatus @default(DRAFT)
  approvedBy        String?
  approvedAt        DateTime?
  remarks           String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  employee    Employee          @relation(fields: [employeeId], references: [id])
  itineraries TravelItinerary[]
  expenses    TravelExpense[]

  @@index([employeeId])
  @@index([status])
  @@map("travel_requests")
}

model TravelItinerary {
  id              String   @id @default(cuid())
  travelRequestId String
  day             Int
  date            DateTime
  fromLocation    String
  toLocation      String
  mode            String
  bookingRef      String?
  departureTime   String?
  arrivalTime     String?
  hotelName       String?
  hotelBookingRef String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  travelRequest TravelRequest @relation(fields: [travelRequestId], references: [id], onDelete: Cascade)

  @@index([travelRequestId])
  @@map("travel_itineraries")
}

model TravelExpense {
  id              String              @id @default(cuid())
  travelRequestId String
  category        String
  description     String
  amount          Float
  currency        String              @default("INR")
  receiptUrl      String?
  expenseDate     DateTime
  status          TravelExpenseStatus @default(DRAFT)
  approvedBy      String?
  approvedAt      DateTime?
  remarks         String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  travelRequest TravelRequest @relation(fields: [travelRequestId], references: [id], onDelete: Cascade)

  @@index([travelRequestId])
  @@index([status])
  @@map("travel_expenses")
}

// ─── BENEFITS MANAGEMENT ─────────────────────────────────────────────

model BenefitPlan {
  id                   String      @id @default(cuid())
  name                 String
  type                 BenefitType
  description          String?
  provider             String?
  coverage             String?
  premium              Float       @default(0)
  employerContribution Float       @default(0)
  employeeContribution Float       @default(0)
  minGradeLevel        Int         @default(0)
  isActive             Boolean     @default(true)
  validFrom            DateTime
  validTo              DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  enrollments BenefitEnrollment[]

  @@index([type])
  @@index([isActive])
  @@map("benefit_plans")
}

model BenefitEnrollment {
  id            String                  @id @default(cuid())
  employeeId    String
  benefitPlanId String
  startDate     DateTime
  endDate       DateTime?
  status        BenefitEnrollmentStatus @default(PENDING)
  nominees      Json?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id])
  benefitPlan BenefitPlan @relation(fields: [benefitPlanId], references: [id])

  @@unique([employeeId, benefitPlanId])
  @@index([employeeId])
  @@index([status])
  @@map("benefit_enrollments")
}

model InsurancePolicy {
  id             String   @id @default(cuid())
  name           String
  policyNumber   String   @unique
  provider       String
  type           String
  coverageAmount Float
  premium        Float
  startDate      DateTime
  endDate        DateTime
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@map("insurance_policies")
}

// ─── CORPORATE SERVICES ──────────────────────────────────────────────

model CorporateService {
  id          String          @id @default(cuid())
  name        String
  category    ServiceCategory
  description String?
  icon        String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  serviceRequests ServiceRequest[]

  @@index([category])
  @@map("corporate_services")
}

model ServiceRequest {
  id                 String               @id @default(cuid())
  employeeId         String
  corporateServiceId String
  subject            String
  description        String
  priority           ServicePriority      @default(MEDIUM)
  status             ServiceRequestStatus @default(OPEN)
  assignedTo         String?
