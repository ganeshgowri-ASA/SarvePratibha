  updatedAt          DateTime             @updatedAt

  employee         Employee         @relation(fields: [employeeId], references: [id])
  corporateService CorporateService @relation(fields: [corporateServiceId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([priority])
