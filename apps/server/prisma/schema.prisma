  @@map("talent_pool_candidates")
}

model SourcePlatform {
  id         String             @id @default(cuid())
  name       String
  type       SourcePlatformType
  apiKey     String?
  apiSecret  String?
  isActive   Boolean            @default(true)
  config     Json?
  lastSyncAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([type])
  @@map("source_platforms")
}

// ─── SECURITY SERVICES ──────────────────────────────────────────────

