  partB            Json?
  totalIncome      Float    @default(0)
  totalTaxPayable  Float    @default(0)
  totalTdsDeducted Float    @default(0)
  generatedAt      DateTime @default(now())
  downloadUrl      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, financialYear])
  @@index([employeeId])
  @@map("form16s")
}

model Investment {
  id             String   @id @default(cuid())
  employeeId     String
  financialYear  String
  section        String
  category       String
  description    String?
  declaredAmount Float    @default(0)
  approvedAmount Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee Employee          @relation(fields: [employeeId], references: [id])
  proofs   InvestmentProof[]

  @@index([employeeId, financialYear])
  @@map("investments")
}

model InvestmentProof {
  id           String                @id @default(cuid())
  investmentId String
  fileName     String
  fileUrl      String
  fileSize     Int?
  status       InvestmentProofStatus @default(PENDING)
  verifiedBy   String?
  verifiedAt   DateTime?
  remarks      String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId])
  @@map("investment_proofs")
}

// ─── REIMBURSEMENTS (Extended) ──────────────────────────────────────

model ReimbursementCategory {
