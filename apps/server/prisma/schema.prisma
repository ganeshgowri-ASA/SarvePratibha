}

// ─── PERFORMANCE MANAGEMENT ─────────────────────────────────────────

model CompetencyFramework {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  level       Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  competencyRatings CompetencyRating[]

  @@map("competency_frameworks")
}

model PerformanceGoal {
  id           String       @id @default(cuid())
  employeeId   String
  title        String
  description  String?
  category     GoalCategory @default(BUSINESS)
  weightage    Float        @default(0)
  targetDate   DateTime?
  status       GoalStatus   @default(NOT_STARTED)
  progress     Int          @default(0)
  selfRating   Float?
  mgrRating    Float?
  cycle        ReviewCycle  @default(ANNUAL)
  year         Int
  parentGoalId String?
  isApproved   Boolean      @default(false)
  approvedAt   DateTime?
  remarks      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  employee        Employee          @relation(fields: [employeeId], references: [id])
  parentGoal      PerformanceGoal?  @relation("GoalCascade", fields: [parentGoalId], references: [id])
  childGoals      PerformanceGoal[] @relation("GoalCascade")
  progressHistory GoalProgress[]
  kpis            KPI[]

  @@index([employeeId])
  @@index([cycle, year])
  @@index([parentGoalId])
  @@index([category])
  @@map("performance_goals")
}

model GoalProgress {
  id         String   @id @default(cuid())
  goalId     String
  employeeId String
  progress   Int
  notes      String?
  createdAt  DateTime @default(now())

  goal     PerformanceGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id])

  @@index([goalId])
  @@index([employeeId])
  @@map("goal_progress")
}

model PerformanceReviewCycle {
  id              String      @id @default(cuid())
  name            String
  cycle           ReviewCycle
  year            Int
  startDate       DateTime
  endDate         DateTime
  selfDeadline    DateTime?
  managerDeadline DateTime?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  reviews Review[]

  @@unique([cycle, year])
  @@index([isActive])
  @@map("performance_review_cycles")
}

model Review {
  id              String       @id @default(cuid())
  revieweeId      String
  reviewerId      String
  cycleId         String?
  cycle           ReviewCycle
  year            Int
  overallRating   Float?
  selfRating      Float?
  managerRating   Float?
  status          ReviewStatus @default(SELF_REVIEW)
  selfComments    String?      @db.Text
  managerComments String?      @db.Text
  promotionRec    Boolean      @default(false)
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reviewee          Employee                @relation("ReviewReviewee", fields: [revieweeId], references: [id])
  reviewer          Employee                @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  reviewCycle       PerformanceReviewCycle? @relation(fields: [cycleId], references: [id])
  ratings           ReviewRating[]
  competencyRatings CompetencyRating[]

  @@unique([revieweeId, cycle, year])
  @@index([reviewerId])
  @@index([cycleId])
  @@map("reviews")
}

model ReviewRating {
  id          String   @id @default(cuid())
  reviewId    String
  kraId       String?
  area        String
  selfRating  Float?
  mgrRating   Float?
  selfComment String?
  mgrComment  String?
  weightage   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  kra    KRA?   @relation(fields: [kraId], references: [id])

  @@index([reviewId])
  @@map("review_ratings")
}

model CompetencyRating {
  id            String   @id @default(cuid())
  reviewId      String
  competencyId  String
  employeeId    String
  selfRating    Float?
  managerRating Float?
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  review     Review              @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  competency CompetencyFramework @relation(fields: [competencyId], references: [id])
  employee   Employee            @relation(fields: [employeeId], references: [id])

  @@unique([reviewId, competencyId])
  @@index([employeeId])
  @@map("competency_ratings")
}

model KRA {
  id          String      @id @default(cuid())
  employeeId  String
  title       String
  description String?
  weightage   Float       @default(0)
  cycle       ReviewCycle @default(ANNUAL)
  year        Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employee Employee       @relation(fields: [employeeId], references: [id])
  kpis     KPI[]
  ratings  ReviewRating[]

  @@index([employeeId])
  @@index([cycle, year])
  @@map("kras")
}

model KPI {
  id        String   @id @default(cuid())
  kraId     String
  goalId    String?
  title     String
  target    String
  actual    String?
  unit      String?
  weightage Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kra  KRA              @relation(fields: [kraId], references: [id], onDelete: Cascade)
  goal PerformanceGoal? @relation(fields: [goalId], references: [id])

  @@index([kraId])
  @@map("kpis")
}

model PIP {
  id          String    @id @default(cuid())
  employeeId  String
  createdById String
  reason      String    @db.Text
  startDate   DateTime
  endDate     DateTime
  status      PIPStatus @default(ACTIVE)
  milestones  Json?
  reviewDates Json?
  outcome     String?
  completedAt DateTime?
  remarks     String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee  Employee @relation("PIPEmployee", fields: [employeeId], references: [id])
  createdBy Employee @relation("PIPCreator", fields: [createdById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("pips")
}

model Feedback360 {
  id            String      @id @default(cuid())
  targetId      String
  requestedById String
  cycle         ReviewCycle
  year          Int
  deadline      DateTime?
  isAnonymous   Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  target      Employee           @relation("Feedback360Target", fields: [targetId], references: [id])
  requestedBy Employee           @relation("Feedback360Requester", fields: [requestedById], references: [id])
  responses   FeedbackResponse[]

  @@index([targetId])
  @@index([requestedById])
  @@map("feedback_360")
}

model FeedbackResponse {
  id            String         @id @default(cuid())
  feedback360Id String
  responderId   String
  status        FeedbackStatus @default(REQUESTED)
  ratings       Json?
  strengths     String?        @db.Text
  improvements  String?        @db.Text
  comments      String?        @db.Text
  submittedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  feedback360 Feedback360 @relation(fields: [feedback360Id], references: [id], onDelete: Cascade)
  responder   Employee    @relation(fields: [responderId], references: [id])

  @@unique([feedback360Id, responderId])
  @@index([responderId])
  @@index([status])
  @@map("feedback_responses")
}

// ─── ATS / RECRUITMENT ──────────────────────────────────────────────

model JobRequisition {
  id              String            @id @default(cuid())
  title           String
  departmentId    String
  designationId   String?
  description     String            @db.Text
  requirements    String?           @db.Text
  skills          String[]
  location        String?
  positions       Int               @default(1)
  filledPositions Int               @default(0)
  minExp          Float?
  maxExp          Float?
  minSalary       Float?
  maxSalary       Float?
  employmentType  EmploymentType    @default(FULL_TIME)
  status          RequisitionStatus @default(DRAFT)
  priority        String            @default("MEDIUM")
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  closingDate     DateTime?
  remarks         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  department  Department   @relation(fields: [departmentId], references: [id])
  designation Designation? @relation(fields: [designationId], references: [id])
  createdBy   Employee     @relation("RequisitionCreator", fields: [createdById], references: [id])
  approvedBy  Employee?    @relation("RequisitionApprover", fields: [approvedById], references: [id])
  jobPostings JobPosting[]

  @@index([departmentId])
  @@index([status])
  @@index([createdById])
  @@map("job_requisitions")
}

model JobPosting {
  id                 String         @id @default(cuid())
  requisitionId      String
  title              String
  departmentId       String
  description        String         @db.Text
  requirements       String?        @db.Text
  skills             String[]
  location           String?
  positions          Int            @default(1)
  minExp             Float?
  maxExp             Float?
  minSalary          Float?
  maxSalary          Float?
  employmentType     EmploymentType @default(FULL_TIME)
  isActive           Boolean        @default(true)
  isPublished        Boolean        @default(false)
  publishedPlatforms String[]
  postedAt           DateTime       @default(now())
  closingDate        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  requisition  JobRequisition @relation(fields: [requisitionId], references: [id])
  department   Department     @relation(fields: [departmentId], references: [id])
  applications Application[]

  // AI Screening
  aiScreeningSessions AIScreeningSession[]
  candidateAIScores   CandidateAIScore[]

  @@index([departmentId])
  @@index([isActive])
  @@index([requisitionId])
  @@map("job_postings")
}

model Candidate {
  id             String             @id @default(cuid())
  firstName      String
  lastName       String
  email          String             @unique
  phone          String?
  resumeUrl      String?
  linkedinUrl    String?
  currentCompany String?
  currentTitle   String?
  totalExp       Float?
  currentSalary  Float?
  expectedSalary Float?
  skills         String[]
  location       String?
  source         SourcePlatformType @default(OTHER)
  sourceDetails  String?
  notes          String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  applications Application[]
  tags         CandidateTag[]
  talentPools  TalentPoolCandidate[]

  @@index([email])
  @@index([source])
  @@map("candidates")
}

model CandidateTag {
  id          String   @id @default(cuid())
  candidateId String
  tag         String
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, tag])
  @@index([tag])
  @@map("candidate_tags")
}

model Application {
  id           String             @id @default(cuid())
  jobPostingId String
  candidateId  String
  status       ApplicationStatus  @default(APPLIED)
  stage        String             @default("APPLIED")
  referredById String?
  source       SourcePlatformType @default(OTHER)
  coverLetter  String?            @db.Text
  remarks      String?
  appliedAt    DateTime           @default(now())
  movedAt      DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  jobPosting JobPosting          @relation(fields: [jobPostingId], references: [id])
  candidate  Candidate           @relation(fields: [candidateId], references: [id])
  referredBy Employee?           @relation(fields: [referredById], references: [id])
  interviews InterviewSchedule[]
  offer      OfferLetter?

  // AI Screening
  aiScreeningSessions AIScreeningSession[]
  candidateAIScores   CandidateAIScore[]

  @@unique([jobPostingId, candidateId])
  @@index([jobPostingId])
  @@index([candidateId])
  @@index([status])
  @@index([stage])
  @@map("applications")
}

model InterviewRound {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schedules InterviewSchedule[]

  @@map("interview_rounds")
}

model InterviewSchedule {
  id            String          @id @default(cuid())
  applicationId String
  interviewerId String
  roundId       String?
  scheduledAt   DateTime
  duration      Int             @default(60)
  round         Int             @default(1)
  mode          String          @default("IN_PERSON")
  location      String?
  meetingLink   String?
  notes         String?
  result        InterviewResult @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  application Application         @relation(fields: [applicationId], references: [id])
  interviewer Employee            @relation("Interviewer", fields: [interviewerId], references: [id])
  roundType   InterviewRound?     @relation(fields: [roundId], references: [id])
  feedbacks   InterviewFeedback[]

  @@index([applicationId])
  @@index([interviewerId])
  @@index([scheduledAt])
  @@map("interview_schedules")
}

model InterviewFeedback {
  id                  String   @id @default(cuid())
  interviewScheduleId String
  interviewerId       String
  technicalRating     Int?
  communicationRating Int?
  cultureFitRating    Int?
  overallRating       Float?
  strengths           String?  @db.Text
  weaknesses          String?  @db.Text
  recommendation      String?
  comments            String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  interviewSchedule InterviewSchedule @relation(fields: [interviewScheduleId], references: [id])
  interviewer       Employee          @relation(fields: [interviewerId], references: [id])

  @@unique([interviewScheduleId, interviewerId])
  @@index([interviewerId])
  @@map("interview_feedbacks")
}

model OfferLetter {
  id              String      @id @default(cuid())
  applicationId   String      @unique
  candidateName   String
  designation     String
  department      String
  joiningDate     DateTime
  basicSalary     Float
  hra             Float       @default(0)
  conveyance      Float       @default(0)
  specialAllow    Float       @default(0)
  otherAllow      Float       @default(0)
  grossSalary     Float
  pfContribution  Float       @default(0)
  esiContribution Float       @default(0)
  professionalTax Float       @default(0)
  tds             Float       @default(0)
  netSalary       Float
  bonus           Float?
  stockOptions    String?
  benefits        String?     @db.Text
  status          OfferStatus @default(DRAFT)
  validUntil      DateTime?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  sentAt          DateTime?
  respondedAt     DateTime?
  remarks         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  application Application @relation(fields: [applicationId], references: [id])
  createdBy   Employee    @relation("OfferCreator", fields: [createdById], references: [id])
  approvedBy  Employee?   @relation("OfferApprover", fields: [approvedById], references: [id])

  @@index([status])
  @@map("offer_letters")
}

model TalentPool {
  id          String   @id @default(cuid())
  name        String
  description String?
